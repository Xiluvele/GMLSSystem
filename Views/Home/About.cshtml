@{
    ViewData["Title"] = "About Us";
}

<div class="container">
    <!-- Hero Section -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-success mb-3">About GLMS</h1>
            <p class="lead text-muted">Global Logistics Management System</p>
            <div class="divider mx-auto my-4"></div>
        </div>
    </div>

    <!-- Mission Section -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-success mb-3"><i class="fas fa-bullseye"></i> Our Mission</h2>
                    <p class="lead">To revolutionize global logistics through innovative technology, seamless integration, and unparalleled efficiency.</p>
                    <p>GLMS empowers businesses to manage their supply chain operations with real-time visibility, automated workflows, and intelligent decision-making tools.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-success mb-3"><i class="fas fa-eye"></i> Our Vision</h2>
                    <p class="lead">To be the world's leading logistics management platform, connecting global supply chains seamlessly.</p>
                    <p>We envision a future where logistics operations are fully integrated, transparent, and optimized for maximum efficiency.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Core Values -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="text-success"><i class="fas fa-gem"></i> Our Core Values</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-chart-line fa-3x text-primary mb-3"></i>
                    <h4>Innovation</h4>
                    <p class="text-muted">Continuously evolving with cutting-edge technology to meet modern logistics challenges.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-shield-alt fa-3x text-success mb-3"></i>
                    <h4>Integrity</h4>
                    <p class="text-muted">Building trust through transparency, security, and reliable service delivery.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-users fa-3x text-info mb-3"></i>
                    <h4>Collaboration</h4>
                    <p class="text-muted">Working together with clients and partners to achieve shared success.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- System Features -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="text-success"><i class="fas fa-cogs"></i> System Features</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <i class="fas fa-file-contract text-primary"></i> Contract Management
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check text-success"></i> Centralized contract repository</li>
                        <li><i class="fas fa-check text-success"></i> Automated status tracking</li>
                        <li><i class="fas fa-check text-success"></i> PDF document upload & storage</li>
                        <li><i class="fas fa-check text-success"></i> Service level management</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <i class="fas fa-truck text-success"></i> Service Requests
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check text-success"></i> Real-time request tracking</li>
                        <li><i class="fas fa-check text-success"></i> Automated validation rules</li>
                        <li><i class="fas fa-check text-success"></i> Status workflow management</li>
                        <li><i class="fas fa-check text-success"></i> Historical request data</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <i class="fas fa-file-invoice-dollar text-warning"></i> Financial Integration
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check text-success"></i> Automated invoice generation</li>
                        <li><i class="fas fa-check text-success"></i> Real-time currency conversion</li>
                        <li><i class="fas fa-check text-success"></i> Multi-currency support</li>
                        <li><i class="fas fa-check text-success"></i> Financial reporting</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row bg-success text-white py-5 mb-5 rounded">
        <div class="col-md-3 text-center">
            <i class="fas fa-building fa-2x mb-2"></i>
            <h2 class="fw-bold">500+</h2>
            <p>Clients Worldwide</p>
        </div>
        <div class="col-md-3 text-center">
            <i class="fas fa-file-contract fa-2x mb-2"></i>
            <h2 class="fw-bold">10,000+</h2>
            <p>Contracts Managed</p>
        </div>
        <div class="col-md-3 text-center">
            <i class="fas fa-truck fa-2x mb-2"></i>
            <h2 class="fw-bold">50,000+</h2>
            <p>Service Requests</p>
        </div>
        <div class="col-md-3 text-center">
            <i class="fas fa-globe fa-2x mb-2"></i>
            <h2 class="fw-bold">50+</h2>
            <p>Countries Served</p>
        </div>
    </div>

    <!-- Technology Stack -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="text-success"><i class="fas fa-code"></i> Technology Stack</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fab fa-microsoft fa-3x text-info"></i>
            <p class="mt-2">ASP.NET Core</p>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fas fa-database fa-3x text-primary"></i>
            <p class="mt-2">SQL Server</p>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fab fa-docker fa-3x text-info"></i>
            <p class="mt-2">Docker</p>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fab fa-js fa-3x text-warning"></i>
            <p class="mt-2">JavaScript</p>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fab fa-bootstrap fa-3x text-purple"></i>
            <p class="mt-2">Bootstrap 5</p>
        </div>
        <div class="col-md-2 col-4 text-center mb-3">
            <i class="fab fa-microsoft fa-3x text-success"></i>
            <p class="mt-2">Entity Framework</p>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="text-success"><i class="fas fa-envelope"></i> Get In Touch</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="col-md-4 text-center mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-map-marker-alt fa-2x text-danger mb-3"></i>
                    <h5>Visit Us</h5>
                    <p class="text-muted">123 Main Street<br />Johannesburg, 2000<br />South Africa</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-envelope fa-2x text-primary mb-3"></i>
                    <h5>Email Us</h5>
                    <p class="text-muted">info@glms.com<br />support@glms.com</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <i class="fas fa-phone fa-2x text-success mb-3"></i>
                    <h5>Call Us</h5>
                    <p class="text-muted">+27 11 123 4567<br />Mon-Fri 8am-5pm</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .divider {
        width: 60px;
        height: 3px;
        background: linear-gradient(135deg, #003b00 100%);
        border-radius: 3px;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

    .text-purple {
        color: #003b00;
    }

    .bg-primary {
        background: linear-gradient(135deg, #003b00 100%) !important;
    }
</style>