@model IEnumerable<GMLSSystem.Models.ServiceRequest>
@using GMLSSystem.Models.Enums

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Request #</th>
                    <th>Contract</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Cost (USD)</th>
                    <th>Cost (ZAR)</th>
                    <th>Request Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr class="@(request.Status == RequestStatus.Pending ? "table-warning" : "")">
                        <td>
                            <strong>@request.RequestNumber</strong>
                        </td>
                        <td>@request.Contract?.ContractNumber</td>
                        <td>@request.Contract?.ClientName</td>
                        <td>@(request.Description?.Length > 50 ? request.Description.Substring(0, 50) + "..." : request.Description)</td>
                        <td>$@request.CostUSD.ToString("N2")</td>
                        <td>R @request.CostZAR.ToString("N2")</td>
                        <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var statusClass = request.Status.ToString() switch
                                {
                                    "Pending" => "warning",
                                    "InProgress" => "info",
                                    "Completed" => "success",
                                    "Cancelled" => "danger",
                                    _ => "secondary"
                                };
                                var statusIcon = request.Status.ToString() switch
                                {
                                    "Pending" => "fa-clock",
                                    "InProgress" => "fa-spinner",
                                    "Completed" => "fa-check-circle",
                                    "Cancelled" => "fa-times-circle",
                                    _ => "fa-question-circle"
                                };
                            }
                            <span class="badge bg-@statusClass">
                                <i class="fas @statusIcon"></i> @request.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@request.ServiceRequestId" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle fa-2x mb-2"></i>
        <p>No service requests found matching your criteria.</p>
    </div>
}