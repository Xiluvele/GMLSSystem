@model GMLSSystem.Models.Invoice
@using GMLSSystem.Models
@{
    Layout = null;
    ViewData["Title"] = "Print Invoice";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.InvoiceNumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
        @@media print {
            .no-print {
                display: none;
            }

            body {
                padding: 20px;
            }
        }

        .invoice-header {
            border-bottom: 2px solid #333;
            margin-bottom: 20px;
            padding-bottom: 10px;
        }

        .company-info {
            text-align: right;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="no-print text-end mb-3">
            <button class="btn btn-primary" onclick="window.print()">
                <i class="fas fa-print"></i> Print
            </button>
            <button class="btn btn-secondary" onclick="window.close()">
                <i class="fas fa-times"></i> Close
            </button>
        </div>

        <div class="invoice">
            <div class="invoice-header">
                <div class="row">
                    <div class="col-md-6">
                        <h2>GLMS</h2>
                        <p>Global Logistics Management System</p>
                    </div>
                    <div class="col-md-6 company-info">
                        <h3>INVOICE</h3>
                        <p># @Model.InvoiceNumber</p>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Bill To:</h5>
                    <p>
                        <strong>@Model.ClientName</strong><br />
                        Contract: @Model.Contract?.ContractNumber
                    </p>
                </div>
                <div class="col-md-6 text-end">
                    <h5>Invoice Details:</h5>
                    <p>
                        Invoice Date: @Model.InvoiceDate.ToString("yyyy-MM-dd")<br />
                        Due Date: @Model.DueDate.ToString("yyyy-MM-dd")<br />
                        Status: @Model.Status
                    </p>
                </div>
            </div>

            <div class="table-responsive mb-4">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.Description</td>
                                    <td class="text-end">@item.Quantity</td>
                                    <td class="text-end">@(Model.Currency == "USD" ? "$" : "R")@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end">@(Model.Currency == "USD" ? "$" : "R")@item.Total.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                            <td class="text-end">@(Model.Currency == "USD" ? "$" : "R")@Model.Subtotal.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Tax (@Model.TaxRate%):</strong></td>
                            <td class="text-end">@(Model.Currency == "USD" ? "$" : "R")@Model.TaxAmount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Total:</strong></td>
                            <td class="text-end"><strong>@(Model.Currency == "USD" ? "$" : "R")@Model.TotalAmount.ToString("N2")</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="alert alert-secondary">
                    <strong>Notes:</strong><br />
                    @Model.Notes
                </div>
            }

            <div class="text-center mt-5">
                <p>Thank you for your business!</p>
                <p>For any questions, please contact finance@glms.com</p>
            </div>
        </div>
    </div>
</body>
</html>