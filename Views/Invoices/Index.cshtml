@model IEnumerable<GMLSSystem.Models.Invoice>
@using GMLSSystem.Models
@{
    ViewData["Title"] = "Invoices";
    var filterType = ViewBag.FilterType as string ?? "All Invoices";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="fas fa-file-invoice-dollar"></i> Invoices</h1>
            <p class="text-muted mb-0">Showing: <strong>@filterType</strong></p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("FinanceUser"))
        {
            <a asp-action="Generate" class="btn btn-primary">
                <i class="fas fa-plus"></i> Generate Invoice
            </a>
        }
    </div>

    <!-- Quick Filter Buttons -->
    <div class="btn-group mb-4 flex-wrap" role="group">
        <a asp-action="Index" class="btn btn-outline-secondary @(filterType == "All Invoices" ? "active" : "")">All</a>
        <a asp-action="UnpaidInvoices" class="btn btn-outline-warning @(filterType == "Unpaid Invoices" ? "active" : "")">Unpaid</a>
        <a asp-action="OverdueInvoices" class="btn btn-outline-danger @(filterType == "Overdue Invoices" ? "active" : "")">Overdue</a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Client</th>
                            <th>Contract</th>
                            <th>Invoice Date</th>
                            <th>Due Date</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            var isOverdue = invoice.DueDate < DateTime.UtcNow && invoice.Status != InvoiceStatus.Paid;
                            <tr class="@(isOverdue ? "table-danger" : "")">
                                <td>
                                    <strong>@invoice.InvoiceNumber</strong>
                                    @if (isOverdue)
                                    {
                                        <br />
                                        <span class="badge bg-danger mt-1">OVERDUE</span>
                                    }
                                </td>
                                <td>@invoice.ClientName</td>
                                <td>@(invoice.Contract?.ContractNumber ?? "N/A")</td>
                                <td>@invoice.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                <td>@invoice.DueDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (invoice.Currency == "USD")
                                    {
                                        <span>$@invoice.TotalAmount.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>R @invoice.TotalAmount.ToString("N2")</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusClass = invoice.Status.ToString() switch
                                        {
                                            "Paid" => "success",
                                            "Sent" => "info",
                                            "Draft" => "secondary",
                                            "Overdue" => "danger",
                                            "Cancelled" => "dark",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@invoice.Status</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@invoice.InvoiceId" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Print" asp-route-id="@invoice.InvoiceId" class="btn btn-sm btn-secondary" target="_blank">
                                        <i class="fas fa-print"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                    No invoices found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>