@model IEnumerable<GMLSSystem.Shared.Models.ServiceRequestDto>

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Request #</th>
                    <th>Contract</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Cost (USD)</th>
                    <th>Cost (ZAR)</th>
                    <th>Request Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    var statusText = request.Status ?? "";
                    var statusClass = statusText switch
                    {
                        "Pending" => "warning",
                        "InProgress" => "info",
                        "Completed" => "success",
                        "Cancelled" => "danger",
                        _ => "secondary"
                    };

                    var statusIcon = statusText switch
                    {
                        "Pending" => "fa-clock",
                        "InProgress" => "fa-spinner",
                        "Completed" => "fa-check-circle",
                        "Cancelled" => "fa-times-circle",
                        _ => "fa-question-circle"
                    };

                    <tr class="@(statusText == "Pending" ? "table-warning" : "")">
                        <td>
                            <strong>@request.RequestNumber</strong>
                        </td>
                        <td>@request.ContractNumber</td>
                        <td>@request.ClientName</td>
                        
                        <td>
                            @(request.Description?.Length > 50
                                ? request.Description.Substring(0, 50) + "..."
                                : request.Description)
                        </td>
                        <td>$@request.CostUSD.ToString("N2")</td>
                        <td>R @request.CostZAR.ToString("N2")</td>
                        <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge bg-@statusClass">
                                <i class="fas @statusIcon"></i> @request.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details"
                               asp-route-id="@request.ServiceRequestId"
                               class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle fa-2x mb-2"></i>
        <p>No service requests found matching your criteria.</p>
    </div>
}