@{
    ViewData["Title"] = "Privacy Statement";
}

<div class="container">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="fas fa-shield-alt"></i> Privacy Statement
            </h1>
            <p class="lead text-muted">Global Logistics Management System</p>
            <div class="divider mx-auto my-4"></div>
            <p class="text-muted">Last Updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>
        </div>
    </div>

    <!-- Introduction -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-info-circle"></i> Introduction</h2>
                    <p>At GLMS ("Global Logistics Management System", "we", "our", or "us"), we are committed to protecting your privacy and ensuring the security of your personal information. This Privacy Statement explains how we collect, use, disclose, and safeguard your information when you use our logistics management platform.</p>
                    <p class="mb-0">By using GLMS, you consent to the data practices described in this statement. Please read this carefully to understand our views and practices regarding your personal data.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Information We Collect -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-database"></i> Information We Collect</h2>
                    <div class="row">
                        <div class="col-md-6">
                            <h5><i class="fas fa-user text-info"></i> Personal Information</h5>
                            <ul>
                                <li>Full name and contact details</li>
                                <li>Email address and phone number</li>
                                <li>Company name and position</li>
                                <li>Username and password (encrypted)</li>
                                <li>Profile preferences</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5><i class="fas fa-building text-info"></i> Business Information</h5>
                            <ul>
                                <li>Contract details and agreements</li>
                                <li>Service requests and logistics data</li>
                                <li>Financial transaction records</li>
                                <li>Client and partner information</li>
                                <li>Uploaded documents (PDF files)</li>
                            </ul>
                        </div>
                    </div>
                    <div class="mt-3">
                        <h5><i class="fas fa-chart-line text-info"></i> Usage Data</h5>
                        <ul>
                            <li>Log files and access timestamps</li>
                            <li>IP addresses and browser information</li>
                            <li>System activity and audit trails</li>
                            <li>Feature usage analytics</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- How We Use Your Information -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-cogs"></i> How We Use Your Information</h2>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="text-center p-3 bg-light rounded">
                                <i class="fas fa-file-contract fa-2x text-primary mb-2"></i>
                                <h6>Contract Management</h6>
                                <p class="small text-muted">Process and manage logistics contracts</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="text-center p-3 bg-light rounded">
                                <i class="fas fa-truck fa-2x text-success mb-2"></i>
                                <h6>Service Delivery</h6>
                                <p class="small text-muted">Fulfill service requests efficiently</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="text-center p-3 bg-light rounded">
                                <i class="fas fa-chart-line fa-2x text-info mb-2"></i>
                                <h6>Analytics & Reporting</h6>
                                <p class="small text-muted">Improve system performance</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Security -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-lock"></i> Data Security</h2>
                    <p>We implement industry-standard security measures to protect your data:</p>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="text-center mb-3">
                                <i class="fas fa-key fa-2x text-warning mb-2"></i>
                                <p class="small mb-0"><strong>Encryption</strong></p>
                                <p class="small text-muted">AES-256 encryption for sensitive data</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center mb-3">
                                <i class="fas fa-shield-alt fa-2x text-success mb-2"></i>
                                <p class="small mb-0"><strong>Secure Authentication</strong></p>
                                <p class="small text-muted">Multi-factor authentication support</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center mb-3">
                                <i class="fas fa-database fa-2x text-info mb-2"></i>
                                <p class="small mb-0"><strong>Secure Storage</strong></p>
                                <p class="small text-muted">Encrypted database and file storage</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Sharing -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-share-alt"></i> Data Sharing & Disclosure</h2>
                    <p>We do not sell your personal information. We may share your data in the following circumstances:</p>
                    <ul>
                        <li><i class="fas fa-check-circle text-success"></i> With your consent or at your direction</li>
                        <li><i class="fas fa-check-circle text-success"></i> To comply with legal obligations</li>
                        <li><i class="fas fa-check-circle text-success"></i> To protect our rights and prevent fraud</li>
                        <li><i class="fas fa-check-circle text-success"></i> With service providers who assist our operations</li>
                        <li><i class="fas fa-check-circle text-success"></i> In connection with business transfers or acquisitions</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Your Rights -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-gavel"></i> Your Rights</h2>
                    <div class="row">
                        <div class="col-md-6">
                            <ul>
                                <li><i class="fas fa-eye text-info"></i> Access your personal data</li>
                                <li><i class="fas fa-edit text-warning"></i> Correct inaccurate information</li>
                                <li><i class="fas fa-trash text-danger"></i> Request deletion of your data</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul>
                                <li><i class="fas fa-download text-success"></i> Data portability</li>
                                <li><i class="fas fa-ban text-secondary"></i> Restrict processing</li>
                                <li><i class="fas fa-comment text-primary"></i> Object to processing</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cookies -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-cookie-bite"></i> Cookies & Tracking</h2>
                    <p>GLMS uses cookies and similar tracking technologies to:</p>
                    <ul>
                        <li>Maintain your session and authentication status</li>
                        <li>Remember your preferences and settings</li>
                        <li>Analyze system performance and usage</li>
                        <li>Provide a personalized user experience</li>
                    </ul>
                    <p class="mb-0">You can control cookie settings through your browser preferences.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Retention -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-clock"></i> Data Retention</h2>
                    <p>We retain your personal data for as long as necessary to:</p>
                    <ul>
                        <li>Provide our services and fulfill contractual obligations</li>
                        <li>Comply with legal and regulatory requirements</li>
                        <li>Resolve disputes and enforce our agreements</li>
                        <li>Maintain audit trails and security logs</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Children's Privacy -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-child"></i> Children's Privacy</h2>
                    <p>GLMS is not intended for children under 16 years of age. We do not knowingly collect personal information from children. If you believe we have collected information from a child, please contact us immediately.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- International Data Transfers -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-globe"></i> International Data Transfers</h2>
                    <p>As a global logistics platform, your information may be transferred to and processed in countries other than your own. We ensure appropriate safeguards are in place to protect your data in accordance with applicable data protection laws.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Changes to This Statement -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-primary"><i class="fas fa-history"></i> Changes to This Privacy Statement</h2>
                    <p>We may update this Privacy Statement from time to time. We will notify you of any material changes by posting the new Privacy Statement on this page and updating the "Last Updated" date.</p>
                    <p>We encourage you to review this Privacy Statement periodically for any changes.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Us -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card bg-primary text-white border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-envelope fa-3x mb-3"></i>
                    <h3>Contact Us</h3>
                    <p>If you have any questions about this Privacy Statement or our data practices, please contact us:</p>
                    <p class="mb-0">
                        <i class="fas fa-envelope"></i> privacy@glms.com<br />
                        <i class="fas fa-phone"></i> +27 11 123 4567<br />
                        <i class="fas fa-map-marker-alt"></i> 123 Main Street, Johannesburg, 2000, South Africa
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .divider {
        width: 60px;
        height: 3px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 3px;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

    .bg-light {
        background-color: #f8f9fa !important;
    }

    .bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    ul {
        padding-left: 1.2rem;
    }

    li {
        margin-bottom: 0.5rem;
    }
</style>