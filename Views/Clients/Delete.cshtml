@model GMLSSystem.Models.Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Delete Client</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this client?
                        <br />
                        <small class="text-muted">This action cannot be undone. All associated contracts and service requests will also be deleted.</small>
                    </div>

                    <div class="client-info mb-4">
                        <h5 class="border-bottom pb-2">
                            <i class="fas fa-building"></i> Client Information
                        </h5>
                        <dl class="row mt-3">
                            <dt class="col-sm-4 text-muted">Company Name</dt>
                            <dd class="col-sm-8">
                                <strong>@Model.Name</strong>
                            </dd>

                            <dt class="col-sm-4 text-muted">Contact Email</dt>
                            <dd class="col-sm-8">
                                <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a>
                            </dd>

                            <dt class="col-sm-4 text-muted">Phone Number</dt>
                            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.ContactPhone) ? "N/A" : Model.ContactPhone)</dd>

                            <dt class="col-sm-4 text-muted">Region</dt>
                            <dd class="col-sm-8">
                                @{
                                    var regionClass = Model.Region?.ToLower() switch
                                    {
                                        "international" => "info",
                                        "johannesburg" => "success",
                                        "cape town" => "primary",
                                        "durban" => "warning",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@regionClass">@(Model.Region ?? "Not specified")</span>
                            </dd>

                            <dt class="col-sm-4 text-muted">Address</dt>
                            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</dd>

                            <dt class="col-sm-4 text-muted">Created Date</dt>
                            <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                        </dl>
                    </div>

                    <!-- Show related data warning -->
                    @if (Model.Contracts != null && Model.Contracts.Any())
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-file-contract"></i>
                            <strong>Warning:</strong> This client has @Model.Contracts.Count active contract(s).
                            <br />
                            <small>Deleting this client will also delete all associated contracts and service requests.</small>
                        </div>
                    }

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ClientId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash-alt"></i> Confirm Delete
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .client-info dl {
        margin-bottom: 0;
    }

    .client-info dt {
        font-weight: 500;
    }

    .alert i {
        margin-right: 8px;
    }
</style>