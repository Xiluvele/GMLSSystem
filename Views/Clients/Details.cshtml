@model GMLSSystem.Models.Client
@{
    ViewData["Title"] = "Client Details";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="fas fa-building"></i> Client Details</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4 text-muted">Company Name</dt>
                                <dd class="col-sm-8">
                                    <strong>@Model.Name</strong>
                                </dd>

                                <dt class="col-sm-4 text-muted">Contact Email</dt>
                                <dd class="col-sm-8">
                                    <a href="mailto:@Model.ContactEmail" class="text-decoration-none">
                                        <i class="fas fa-envelope"></i> @Model.ContactEmail
                                    </a>
                                </dd>

                                <dt class="col-sm-4 text-muted">Phone Number</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.ContactPhone))
                                    {
                                        <a href="tel:@Model.ContactPhone">
                                            <i class="fas fa-phone"></i> @Model.ContactPhone
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4 text-muted">Region</dt>
                                <dd class="col-sm-8">
                                    @{
                                        var regionClass = Model.Region?.ToLower() switch
                                        {
                                            "international" => "info",
                                            "johannesburg" => "success",
                                            "cape town" => "primary",
                                            "durban" => "warning",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@regionClass">
                                        <i class="fas fa-globe"></i> @(Model.Region ?? "Not specified")
                                    </span>
                                </dd>

                                <dt class="col-sm-4 text-muted">Created Date</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-calendar"></i> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                </dd>
                            </dl>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="mt-3">
                            <h6 class="text-muted"><i class="fas fa-location-dot"></i> Address</h6>
                            <p class="bg-light p-3 rounded">@Model.Address</p>
                        </div>
                    }

                    <!-- Contracts Section -->
                    <div class="mt-4">
                        <h5 class="border-bottom pb-2">
                            <i class="fas fa-file-contract"></i> Contracts
                        </h5>
                        @if (Model.Contracts != null && Model.Contracts.Any())
                        {
                            <div class="table-responsive mt-3">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Contract #</th>
                                            <th>Start Date</th>
                                            <th>End Date</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var contract in Model.Contracts)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@contract.ContractNumber</strong>
                                                    <br />
                                                    <small class="text-muted">@contract.ServiceLevel</small>
                                                </td>
                                                <td>@contract.StartDate.ToShortDateString()</td>
                                                <td>@contract.EndDate.ToShortDateString()</td>
                                                <td>
                                                    <span class="badge bg-@(contract.Status.ToString() == "Active" ? "success" : 
                                                                           contract.Status.ToString() == "Draft" ? "warning" : 
                                                                           contract.Status.ToString() == "Expired" ? "danger" : "secondary")">
                                                        @contract.Status
                                                    </span>
                                                </td>
                                                <td>
                                                    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.ContractId" 
                                                       class="btn btn-sm btn-outline-info">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light text-center py-3">
                                <i class="fas fa-file-contract fa-2x text-muted mb-2"></i>
                                <p class="mb-0 text-muted">No contracts found for this client.</p>
                                <a asp-controller="Contracts" asp-action="Create" asp-route-clientId="@Model.ClientId" class="btn btn-sm btn-primary mt-2">
                                    <i class="fas fa-plus"></i> Create Contract
                                </a>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-warning text-white">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        border-bottom: none;
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(102, 126, 234, 0.05);
        cursor: pointer;
    }
    
    dt {
        font-weight: 500;
    }
    
    .rounded {
        border-radius: 8px !important;
    }
</style>